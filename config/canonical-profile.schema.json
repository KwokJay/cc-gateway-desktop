{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CC Gateway Canonical Profile",
  "description": "Shared canonical identity and environment fingerprint contract for aggressive-mode parity across TypeScript prototype and Rust core",
  "type": "object",
  "required": ["version", "identity", "env", "prompt_env", "process"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for forward compatibility",
      "enum": ["1.0"]
    },
    "identity": {
      "type": "object",
      "description": "Canonical device identity",
      "required": ["device_id", "email"],
      "properties": {
        "device_id": {
          "type": "string",
          "description": "64-char hex device identifier",
          "pattern": "^[a-f0-9]{64}$"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Canonical account email"
        }
      }
    },
    "env": {
      "type": "object",
      "description": "Raw environment fingerprint with 40+ dimensions - stored as flexible JSON map",
      "required": [
        "platform",
        "platform_raw",
        "arch",
        "node_version",
        "terminal",
        "package_managers",
        "runtimes",
        "is_running_with_bun",
        "is_ci",
        "is_claude_ai_auth",
        "version",
        "version_base",
        "build_time",
        "deployment_environment",
        "vcs"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "description": "OS platform: darwin, linux, win32"
        },
        "platform_raw": {
          "type": "string",
          "description": "Raw platform string"
        },
        "arch": {
          "type": "string",
          "description": "CPU architecture: arm64, x64, etc"
        },
        "node_version": {
          "type": "string",
          "description": "Node.js version string"
        },
        "terminal": {
          "type": "string",
          "description": "Terminal emulator name"
        },
        "package_managers": {
          "type": "string",
          "description": "Comma-separated list of available package managers"
        },
        "runtimes": {
          "type": "string",
          "description": "Comma-separated list of available runtimes"
        },
        "is_running_with_bun": {
          "type": "boolean",
          "description": "Whether running under Bun runtime"
        },
        "is_ci": {
          "type": "boolean",
          "description": "Whether running in CI environment"
        },
        "is_claubbit": {
          "type": "boolean",
          "description": "Claubbit mode flag"
        },
        "is_claude_code_remote": {
          "type": "boolean",
          "description": "Remote Claude Code mode flag"
        },
        "is_local_agent_mode": {
          "type": "boolean",
          "description": "Local agent mode flag"
        },
        "is_conductor": {
          "type": "boolean",
          "description": "Conductor mode flag"
        },
        "is_github_action": {
          "type": "boolean",
          "description": "GitHub Action environment flag"
        },
        "is_claude_code_action": {
          "type": "boolean",
          "description": "Claude Code Action flag"
        },
        "is_claude_ai_auth": {
          "type": "boolean",
          "description": "Claude AI authentication mode"
        },
        "version": {
          "type": "string",
          "description": "Claude Code full version"
        },
        "version_base": {
          "type": "string",
          "description": "Claude Code base version"
        },
        "build_time": {
          "type": "string",
          "format": "date-time",
          "description": "Build timestamp ISO 8601"
        },
        "deployment_environment": {
          "type": "string",
          "description": "Deployment environment identifier"
        },
        "vcs": {
          "type": "string",
          "description": "Version control system: git, hg, etc"
        },
        "shell": {
          "type": "string",
          "description": "Shell type: zsh, bash, fish, etc"
        },
        "shell_version": {
          "type": "string",
          "description": "Shell version string"
        },
        "locale": {
          "type": "string",
          "description": "System locale"
        },
        "timezone": {
          "type": "string",
          "description": "System timezone"
        },
        "editor": {
          "type": "string",
          "description": "Default editor"
        },
        "cpu_cores": {
          "type": "number",
          "description": "Number of CPU cores"
        },
        "total_memory": {
          "type": "number",
          "description": "Total system memory in bytes"
        },
        "hostname": {
          "type": "string",
          "description": "Machine hostname"
        },
        "username": {
          "type": "string",
          "description": "System username"
        },
        "home_dir": {
          "type": "string",
          "description": "User home directory path"
        },
        "os_release": {
          "type": "string",
          "description": "OS release version"
        },
        "kernel_version": {
          "type": "string",
          "description": "Kernel version string"
        },
        "docker_available": {
          "type": "boolean",
          "description": "Whether Docker is available"
        },
        "git_version": {
          "type": "string",
          "description": "Git version string"
        },
        "python_version": {
          "type": "string",
          "description": "Python version if available"
        },
        "screen_resolution": {
          "type": "string",
          "description": "Screen resolution WxH"
        },
        "color_depth": {
          "type": "number",
          "description": "Display color depth"
        },
        "network_interfaces": {
          "type": "string",
          "description": "Available network interfaces"
        },
        "ipv4_address": {
          "type": "string",
          "description": "Primary IPv4 address"
        },
        "ipv6_address": {
          "type": "string",
          "description": "Primary IPv6 address"
        },
        "mac_address": {
          "type": "string",
          "description": "Primary MAC address"
        },
        "uptime": {
          "type": "number",
          "description": "System uptime in seconds"
        },
        "boot_time": {
          "type": "string",
          "format": "date-time",
          "description": "System boot timestamp"
        }
      },
      "additionalProperties": true
    },
    "prompt_env": {
      "type": "object",
      "description": "System prompt environment masking - must be consistent with env",
      "required": ["platform", "shell", "os_version", "working_dir"],
      "properties": {
        "platform": {
          "type": "string",
          "description": "Platform shown in prompt - must match env.platform"
        },
        "shell": {
          "type": "string",
          "description": "Shell name shown in prompt"
        },
        "os_version": {
          "type": "string",
          "description": "OS version shown in prompt (uname -sr output)"
        },
        "working_dir": {
          "type": "string",
          "description": "Canonical home directory path prefix"
        }
      }
    },
    "process": {
      "type": "object",
      "description": "Canonical process metrics - should look like a real machine",
      "required": ["constrained_memory", "rss_range", "heap_total_range", "heap_used_range"],
      "properties": {
        "constrained_memory": {
          "type": "number",
          "description": "Physical RAM in bytes (e.g., 34359738368 for 32GB)",
          "minimum": 1073741824
        },
        "rss_range": {
          "type": "array",
          "description": "Resident Set Size range [min, max] in bytes",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "heap_total_range": {
          "type": "array",
          "description": "V8 heap total range [min, max] in bytes",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "heap_used_range": {
          "type": "array",
          "description": "V8 heap used range [min, max] in bytes",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "rewrite_policy": {
      "type": "object",
      "description": "Metadata for rewrite behavior - not yet consumed by rewriter logic",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["aggressive", "conservative", "passthrough"],
          "description": "Rewrite aggressiveness level"
        },
        "strip_billing_header": {
          "type": "boolean",
          "description": "Whether to strip x-anthropic-billing-header"
        },
        "normalize_timestamps": {
          "type": "boolean",
          "description": "Whether to normalize event timestamps"
        },
        "preserve_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Field paths to preserve from original request"
        }
      }
    }
  }
}
